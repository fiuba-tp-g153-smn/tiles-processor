LOG_LEVEL=INFO

DATA_DIR=/app/data

# Ports
S3_TILES_DATA_PORT=9000      # host port -> RustFS S3 API (container :9000)
RUSTFS_CONSOLE_PORT=9001     # host port -> RustFS console UI (container :9001)

# RustFS object storage — single shared root credential.
# RustFS multi-user IAM cannot be provisioned non-interactively at boot, so every
# consumer (this app + external data-service/alerts-service) authenticates with
# this one key. Create scoped per-service keys later via the RustFS console
# (http://localhost:${RUSTFS_CONSOLE_PORT}) if isolation is needed.
RUSTFS_ACCESS_KEY=rustfsadmin
RUSTFS_SECRET_KEY=REPLACE_WITH_SECURE_PASSWORD
# CORS origins for the S3 API / console (tighten from * for prod).
RUSTFS_CORS_ALLOWED_ORIGINS=*
RUSTFS_CONSOLE_CORS_ALLOWED_ORIGINS=*
# Dev only (make up): RustFS runs as this host UID:GID so bind-mounted ./data_rustfs
# files are owned by you. Defaults to 1000:1000; override if your user differs.
# RUSTFS_UID=1000
# RUSTFS_GID=1000

# S3 Root Configuration (inert — retained for future console-based provisioning)
S3_ROOT_USER=root_admin
S3_ROOT_PASSWORD=REPLACE_WITH_SECURE_PASSWORD

# S3 Tiles Data Configuration
S3_TILES_DATA_ENDPOINT=rustfs:9000
S3_TILES_DATA_BUCKET_NAME=tiles-data
S3_TILES_DATA_SECURE=false
# Max concurrent uploads per S3 client (tiles/COG/GRIB); also sizes the pool.
S3_UPLOAD_CONCURRENCY=32

# Work units a worker processes concurrently (overlaps a unit's upload tail with
# the next unit's compute). Total concurrent PUTs ≈ workers × this × S3_UPLOAD_CONCURRENCY.
WORKER_CONCURRENCY=2

# The app authenticates to RustFS with these — they MUST equal RUSTFS_ACCESS_KEY /
# RUSTFS_SECRET_KEY above (single shared root key; .env cannot self-reference).
S3_TILES_DATA_TILES_PROCESSOR_USER=rustfsadmin
S3_TILES_DATA_TILES_PROCESSOR_PASSWORD=REPLACE_WITH_SECURE_PASSWORD
# Inert (retained for future console-based per-service provisioning)
S3_TILES_DATA_DATA_SERVICE_USER=data_service
S3_TILES_DATA_DATA_SERVICE_PASSWORD=REPLACE_WITH_SECURE_PASSWORD

# S3 Intersection Data Configuration (alerts-service geojson layers)
S3_INTERSECTION_DATA_BUCKET_NAME=intersection-data
S3_INTERSECTION_DATA_ALERTS_SERVICE_USER=alerts_service
S3_INTERSECTION_DATA_ALERTS_SERVICE_PASSWORD=REPLACE_WITH_SECURE_PASSWORD

# S3 Basemap Data Configuration (basemap tiles)
S3_BASEMAP_BUCKET_NAME=basemap-tiles

RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672
RABBITMQ_USER=tiles_processor
RABBITMQ_PASSWORD=REPLACE_WITH_SECURE_PASSWORD
RABBITMQ_QUEUE=tiles_work_queue
# Lightweight work queues, split so radar and WRF don't block each other.
# Workers round-robin them; the producer routes radar -> radar, configured WRF
# products -> wrf. Light workers set WORKER_TYPE=light (see docker-compose).
RABBITMQ_RADAR_LIGHT_QUEUE=tiles_radar_light_queue
RABBITMQ_WRF_LIGHT_QUEUE=tiles_wrf_light_queue
RABBITMQ_DLQ=tiles_dead_letter_queue
RABBITMQ_DLX=tiles_dlx

# Status metrics API (host port; container always serves on 6020).
# The UI lives in the visualizer app, which calls this API cross-origin.
METRICS_API_PORT=6020
# API key for the metrics API's write endpoints (X-API-Key header on POST /api/import).
# Leave blank to disable writes (they fail closed with 503). GET reads stay open.
METRICS_API_KEY=

# Fine-grid resolution (degrees) for smoothing ECMWF total-precipitation tiles via
# bilinear upsampling before colorizing. Only affects visualization tiles (the COG
# keeps native resolution). Finer = smoother but more memory. 0 disables smoothing.
ECMWF_TP_SMOOTHING_RESOLUTION_DEG=0.01

# Ordered ECMWF Open Data mirrors to try when downloading GRIBs (comma-separated).
# The producer falls back to the next mirror on a transient (503) failure, so one
# mirror being down does not block ingestion. First working mirror wins. Options:
# ecmwf, azure, aws.
ECMWF_OPENDATA_SOURCES=ecmwf,azure,aws

JOB_TTL_MINUTES=20

# Memory optimization: limit GDAL/PROJ caches
GDAL_CACHEMAX=128
CPL_VSIL_CURL_CACHE_SIZE=16777216 # 16MB
