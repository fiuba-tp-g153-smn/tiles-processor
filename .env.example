LOG_LEVEL=INFO
BAND_13_SCHEDULE_CRON="*/5 * * * *"
BAND_9_SCHEDULE_CRON="*/5 * * * *"
ENABLE_BAND_13=true
ENABLE_BAND_9=true
TZ=America/Argentina/Buenos_Aires
TMP_DIR_HOST=./.tmp
TMP_DIR_CONTAINER=/app/.tmp

# Scheduler persistence (SQLite database)
# Host directory for the scheduler database (mounted as volume)
SCHEDULER_DB_HOST_DIR=./.tmp
# Container directory for the scheduler database
SCHEDULER_DB_CONTAINER_DIR=/app/.scheduler
# Full path to the SQLite database file inside the container
SCHEDULER_DB_PATH=/app/.scheduler/jobs.db

# Bounding box for clipping satellite imagery (EPSG:4326 coordinates)
# Default: Argentina region with margin
BOUNDS_MINX=-90.0
BOUNDS_MINY=-60.0
BOUNDS_MAXX=-30.0
BOUNDS_MAXY=-15.0
