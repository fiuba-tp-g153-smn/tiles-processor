LOG_LEVEL=INFO
BAND_13_SCHEDULE_CRON="*/30 * * * *"
BAND_9_SCHEDULE_CRON="*/30 * * * *"
ENABLE_BAND_13=true
ENABLE_BAND_9=true
TZ=America/Argentina/Buenos_Aires
TMP_DIR_HOST=./.tmp
TMP_DIR_CONTAINER=/app/.tmp

# Bounding box for clipping satellite imagery (EPSG:4326 coordinates)
# Default: Argentina region with margin
BOUNDS_MINX=-90.0
BOUNDS_MINY=-60.0
BOUNDS_MAXX=-30.0
BOUNDS_MAXY=-15.0
