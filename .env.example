LOG_LEVEL=INFO

DATA_DIR=/app/data

# Ports
S3_TILES_DATA_PORT=9000
MINIO_CONSOLE_PORT=9001

# Minio Root Configuration (Internal Admin)
MINIO_ROOT_USER=root_admin
MINIO_ROOT_PASSWORD=REPLACE_WITH_SECURE_PASSWORD

# S3 Tiles Data Configuration
S3_TILES_DATA_ENDPOINT=minio:9000
S3_TILES_DATA_BUCKET_NAME=tiles-data
S3_TILES_DATA_SECURE=false

S3_TILES_DATA_TILES_PROCESSOR_USER=tiles_processor
S3_TILES_DATA_TILES_PROCESSOR_PASSWORD=REPLACE_WITH_SECURE_PASSWORD
S3_TILES_DATA_DATA_SERVICE_USER=data_service
S3_TILES_DATA_DATA_SERVICE_PASSWORD=REPLACE_WITH_SECURE_PASSWORD

RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672
RABBITMQ_USER=tiles_processor
RABBITMQ_PASSWORD=REPLACE_WITH_SECURE_PASSWORD
RABBITMQ_QUEUE=tiles_work_queue
RABBITMQ_DLQ=tiles_dead_letter_queue
RABBITMQ_DLX=tiles_dlx

JOB_TTL_MINUTES=20
