LOG_LEVEL=INFO

# Data directory (single volume mount for all persistent data)
DATA_DIR_HOST=./data
DATA_DIR_CONTAINER=/app/data

# S3 Tiles Data Configuration
S3_TILES_DATA_ENDPOINT=minio:9000
S3_TILES_DATA_ACCESS_KEY=minioadmin
S3_TILES_DATA_SECRET_KEY=minioadmin
S3_TILES_DATA_BUCKET_NAME=tiles-data
S3_TILES_DATA_SECURE=false

# Ports
S3_TILES_DATA_PORT=9000
MINIO_CONSOLE_PORT=9001
